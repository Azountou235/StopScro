import { SearchBar } from '@/components/SearchBar'
import { StatsCounter } from '@/components/StatsCounter'
import { ScammerCard } from '@/components/ScammerCard'
import { prisma } from '@/lib/prisma'

export const dynamic = 'force-dynamic' // Pour toujours avoir les données fraîches

export default async function Home() {
  const totalScammers = await prisma.scammer.count()
  const countries = await prisma.country.findMany({ select: { name: true, flag: true } })
  const latestScammers = await prisma.scammer.findMany({
    take: 6,
    orderBy: { createdAt: 'desc' },
    include: { country: true },
  })

  return (
    <div className="px-6 py-12 max-w-7xl mx-auto">
      <h1 className="text-5xl font-extrabold text-center mb-4 bg-gradient-to-r from-blue-400 to-cyan-300 bg-clip-text text-transparent">
        StopScro
      </h1>
      <p className="text-center text-gray-400 text-xl mb-10">Vérifiez avant de faire confiance.</p>
      <SearchBar />
      <StatsCounter totalScammers={totalScammers} countries={countries} />
      <section className="mt-16">
        <h2 className="text-2xl font-bold mb-6">🕒 Derniers signalements</h2>
        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {latestScammers.map((s) => (
            <ScammerCard key={s.id} scammer={s} />
          ))}
        </div>
      </section>
    </div>
  )
}
